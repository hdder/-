<Window x:Class="ZsxqForwarder.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="知识星球转发器"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        StateChanged="OnStateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="知识星球转发器" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnMonitor" Content="开始监控" Padding="12,6" Margin="0,0,8,0"
                            Click="OnMonitorToggle"/>
                    <Button x:Name="BtnSettings" Content="设置" Padding="12,6"
                            Click="OnSettingsClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: Three columns -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Group List with Add/Remove -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="我的星球" FontWeight="SemiBold"
                               FontSize="14" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Add group input -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="GroupUrlInput" Grid.Column="0"
                                 ToolTip="输入星球URL或ID"
                                 Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="+" Padding="8,4"
                                Click="OnAddGroup"/>
                    </Grid>

                    <ListBox x:Name="GroupList"
                             SelectionChanged="OnGroupSelected"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="ID: "/><Run Text="{Binding GroupId}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="x" FontSize="10"
                                            Padding="4,2" Margin="4,0,0,0"
                                            Click="OnRemoveGroup" Tag="{Binding GroupId}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Column 2: Topic List -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="4,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="TopicTitle" Text="帖子列表" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TopicCount" Text="" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <Button x:Name="BtnLoadMore" DockPanel.Dock="Bottom"
                            Content="加载更多" HorizontalAlignment="Center"
                            Margin="0,8" Padding="24,6" Visibility="Collapsed"
                            Click="OnLoadMoreClick"/>

                    <!-- Loading indicator -->
                    <StackPanel x:Name="TopicsLoading" DockPanel.Dock="Top"
                                HorizontalAlignment="Center" Margin="0,40,0,0"
                                Visibility="Collapsed">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="3"/>
                        <TextBlock Text="加载中..." FontSize="12" Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ListBox x:Name="TopicList"
                             SelectionChanged="OnTopicSelected"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,2">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border Background="#E3F2FD" CornerRadius="3" Padding="4,1">
                                                <TextBlock Text="{Binding Type}" FontSize="10"
                                                           Foreground="#1565C0"/>
                                            </Border>
                                            <TextBlock Text="{Binding AuthorName}"
                                                       FontSize="12" FontWeight="Medium" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="13"
                                                   TextWrapping="Wrap" MaxHeight="60"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineStackingStrategy="MaxHeight"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Like "/><Run Text="{Binding LikesCount}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0">
                                                <Run Text="Comment "/><Run Text="{Binding CommentsCount}"/>
                                            </TextBlock>
                                            <Border Background="#FFF3E0" CornerRadius="3" Padding="4,1" Margin="12,0,0,0"
                                                    Visibility="{Binding Digested, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="精华" FontSize="10" Foreground="#E65100"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Column 3: Detail / Actions -->
            <Border Grid.Column="4" Style="{StaticResource CardBorder}" Margin="4,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="详情" FontWeight="SemiBold"
                               FontSize="14" Margin="0,0,0,12"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Topic Detail -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="TopicDetail">
                            <!-- Placeholder -->
                            <TextBlock x:Name="DetailPlaceholder"
                                       Text="选择一个帖子查看详情"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>

                            <!-- Author -->
                            <StackPanel x:Name="DetailAuthor" Orientation="Horizontal"
                                        Margin="0,0,0,12" Visibility="Collapsed">
                                <Ellipse Width="32" Height="32" Margin="0,0,8,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="#E0E0E0"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="DetailAuthorName" FontWeight="Medium" FontSize="13"/>
                                    <TextBlock x:Name="DetailTime" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Content -->
                            <TextBlock x:Name="DetailText" TextWrapping="Wrap" FontSize="14"
                                       LineHeight="22" Visibility="Collapsed"/>

                            <!-- Images -->
                            <ItemsControl x:Name="DetailImages" Margin="0,12,0,0" Visibility="Collapsed">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,4,4" CornerRadius="4"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <Image Source="{Binding}" Width="120" Height="120"
                                                   Stretch="UniformToFill" StretchDirection="Both"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Stats -->
                            <StackPanel x:Name="DetailStats" Orientation="Horizontal"
                                        Margin="0,16,0,0" Visibility="Collapsed">
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="Like "/><Run x:Name="DetailLikes" Text="0"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0">
                                    <Run Text="Comment "/><Run x:Name="DetailComments" Text="0"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Comments -->
                            <TextBlock x:Name="CommentsHeader" Text="评论" FontWeight="SemiBold"
                                       FontSize="13" Margin="0,16,0,8" Visibility="Collapsed"/>
                            <ItemsControl x:Name="CommentsList" Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F8F8" CornerRadius="4"
                                                Padding="10" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Owner.Name}" FontSize="12"
                                                           FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                           FontSize="12" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="MonitorDot" Width="8" Height="8" Fill="#BDBDBD" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="MonitorStatus" Text="监控未启动" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="SyncTime" Text="" Grid.Column="1" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
