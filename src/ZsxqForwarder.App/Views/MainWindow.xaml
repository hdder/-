<Window x:Class="ZsxqForwarder.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="知识星球转发器"
        Width="1000" Height="750"
        MinWidth="700" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        StateChanged="OnStateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="知识星球转发器" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="MonitorDot" Width="8" Height="8" Fill="#BDBDBD" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="MonitorStatus" Text="监控未启动" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="BtnMonitor" Content="开始监控" Padding="12,6" Margin="0,0,8,0"
                            Click="OnMonitorToggle"/>
                    <Button Content="转发日志" Padding="12,6" Margin="0,0,8,0"
                            Click="OnShowLogs"/>
                    <Button x:Name="BtnSettings" Content="设置" Padding="12,6"
                            Click="OnSettingsClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: Two columns -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Group List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,4,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="我的星球" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnSync" Content="同步" Padding="8,4" FontSize="11"
                                Margin="8,0,0,0" Click="OnSyncClick" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="SyncPanel" DockPanel.Dock="Bottom" Margin="0,4,0,0"
                                Visibility="Collapsed">
                        <ProgressBar x:Name="SyncProgress" IsIndeterminate="True" Height="3"/>
                        <TextBlock x:Name="SyncStatusText" Text="同步中..." FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ListBox x:Name="GroupList"
                             SelectionChanged="OnGroupSelected"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                            Margin="0,0,8,0" Background="#E0E0E0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Column 2: Topic List with inline images -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="4,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock x:Name="TopicTitle" Text="帖子列表" FontWeight="SemiBold"
                                           FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="TopicCount" Text="" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="日期" FontSize="12" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <DatePicker x:Name="TopicDatePicker" SelectedDateChanged="OnDateChanged"
                                            Width="130" FontSize="12"/>
                                <Button x:Name="BtnClearDate" Content="全部" Padding="6,3" FontSize="11"
                                        Margin="4,0,0,0" Click="OnClearDateFilter"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Button x:Name="BtnLoadMore" DockPanel.Dock="Bottom"
                            Content="加载更多" HorizontalAlignment="Center"
                            Margin="0,8" Padding="24,6" Visibility="Collapsed"
                            Click="OnLoadMoreClick"/>

                    <StackPanel x:Name="TopicsLoading" DockPanel.Dock="Top"
                                HorizontalAlignment="Center" Margin="0,40,0,0"
                                Visibility="Collapsed">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="3"/>
                        <TextBlock Text="加载中..." FontSize="12" Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TopicList" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,8" Background="White"
                                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <!-- Header row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border Background="#E3F2FD" CornerRadius="3" Padding="4,1">
                                                    <TextBlock Text="{Binding Type}" FontSize="10" Foreground="#1565C0"/>
                                                </Border>
                                                <TextBlock Text="{Binding AuthorName}" FontSize="13"
                                                           FontWeight="SemiBold" Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Content text -->
                                            <TextBlock Text="{Binding DisplayText}" FontSize="14"
                                                       TextWrapping="Wrap" LineHeight="22"
                                                       Margin="0,0,0,8"/>

                                            <!-- Inline images -->
                                            <ItemsControl ItemsSource="{Binding ImageUrls}" Margin="0,0,0,8">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,4,4" CornerRadius="4"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                            <Image Source="{Binding}" MaxWidth="300" MaxHeight="300"
                                                                   Stretch="Uniform" StretchDirection="Both"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Footer: stats + actions -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="赞 "/><Run Text="{Binding LikesCount}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0">
                                                        <Run Text="评 "/><Run Text="{Binding CommentsCount}"/>
                                                    </TextBlock>
                                                    <Border Background="#FFF3E0" CornerRadius="3" Padding="4,1" Margin="12,0,0,0"
                                                            Visibility="{Binding Digested, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="精华" FontSize="10" Foreground="#E65100"/>
                                                    </Border>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="补发" FontSize="10"
                                                        Padding="8,2" Margin="4,0,0,0"
                                                        Click="OnTopicResendClick"
                                                        Tag="{Binding TopicId}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SyncTime" Text="" Grid.Column="1" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
