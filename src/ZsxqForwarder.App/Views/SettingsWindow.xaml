<Window x:Class="ZsxqForwarder.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="600" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- Tab 1: 星球管理 -->
            <TabItem Header="星球管理">
                <StackPanel Margin="12">
                    <TextBlock Text="添加星球" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="GroupUrlInput" Grid.Column="0"
                                 ToolTip="输入星球URL或ID"
                                 Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="添加" Padding="16,6"
                                Click="OnAddGroup"/>
                    </Grid>

                    <TextBlock Text="已添加的星球" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <ListBox x:Name="GroupConfigList" Height="320"
                             BorderBrush="{StaticResource BorderBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="470">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="ID: "/><Run Text="{Binding GroupId}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="删除" FontSize="11"
                                            Padding="8,4" Margin="4,0,0,0"
                                            Click="OnRemoveGroup" Tag="{Binding GroupId}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>

            <!-- Tab 2: 转发规则 -->
            <TabItem Header="转发规则">
                <StackPanel Margin="12">
                    <TextBlock Text="每条规则：从一个星球转发到一个机器人" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <!-- Add rule -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="添加转发规则" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <TextBlock Text="选择星球" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <ComboBox x:Name="RuleGroupCombo" Margin="0,0,0,8"
                                      DisplayMemberPath="Name"/>
                            <TextBlock Text="转发到" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <ComboBox x:Name="RuleForwarderType" Margin="0,0,0,8">
                                <ComboBoxItem Content="钉钉" Tag="DingTalk"/>
                                <ComboBoxItem Content="飞书" Tag="Feishu"/>
                            </ComboBox>
                            <TextBlock Text="Webhook URL" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="RuleWebhookUrl" Margin="0,0,0,8"/>
                            <TextBlock Text="加签密钥（仅钉钉需要）" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="RuleSecret" Margin="0,0,0,8"/>
                            <Button Content="添加规则" Padding="16,6" HorizontalAlignment="Left"
                                    Click="OnAddRule"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="已有规则" FontWeight="SemiBold" FontSize="13" Margin="0,12,0,8"/>
                    <ListBox x:Name="ForwardRuleList" Height="180"
                             BorderBrush="{StaticResource BorderBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="470">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="12">
                                            <Run Text="{Binding GroupName}" FontWeight="Medium"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding ForwarderType}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding WebhookUrl}" FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}"
                                              VerticalAlignment="Center" Margin="4,0"/>
                                    <Button Grid.Column="1" Content="删除" FontSize="10"
                                            Padding="6,2" Margin="40,0,0,0"
                                            Click="OnRemoveRule" Tag="{Binding GroupId}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>

            <!-- Tab 3: 监控设置 -->
            <TabItem Header="监控设置">
                <StackPanel Margin="12">
                    <TextBlock Text="轮询间隔（秒）" FontSize="13" Margin="0,0,0,4"/>
                    <Slider x:Name="MonitorInterval" Minimum="10" Maximum="300" Value="30"
                            TickFrequency="10" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="IntervalDisplay" Text="30 秒" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 4: 账号 -->
            <TabItem Header="账号">
                <StackPanel Margin="12">
                    <TextBlock Text="当前登录状态" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock x:Name="LoginStatus" Text="已登录" FontSize="14" FontWeight="Medium"/>
                    <Button Content="退出登录" Margin="0,16,0,0" Padding="16,8"
                            Click="OnLogout" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Click="OnCancel" Padding="16,6" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="#333"/>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="保存" Click="OnSave" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
