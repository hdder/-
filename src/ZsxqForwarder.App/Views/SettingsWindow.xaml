<Window x:Class="ZsxqForwarder.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="500" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabs -->
        <TabControl Grid.Row="1">
            <!-- Forwarders Tab -->
            <TabItem Header="转发设置">
                <ScrollViewer Padding="12">
                    <StackPanel>
                        <!-- Telegram -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <CheckBox x:Name="TelegramEnabled" Content="Telegram" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Bot Token" FontSize="12" Margin="0,8,0,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox x:Name="TelegramBotToken" Margin="0,0,0,8"/>
                                <TextBlock Text="Chat ID" FontSize="12" Margin="0,0,0,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox x:Name="TelegramChatId"/>
                            </StackPanel>
                        </Border>

                        <!-- WeChat -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <CheckBox x:Name="WechatEnabled" Content="企业微信" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Webhook URL" FontSize="12" Margin="0,8,0,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox x:Name="WechatWebhook"/>
                            </StackPanel>
                        </Border>

                        <!-- Feishu -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <CheckBox x:Name="FeishuEnabled" Content="飞书" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Webhook URL" FontSize="12" Margin="0,8,0,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox x:Name="FeishuWebhook"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Monitor Tab -->
            <TabItem Header="监控设置">
                <StackPanel Padding="12">
                    <TextBlock Text="轮询间隔（秒）" FontSize="13" Margin="0,0,0,4"/>
                    <Slider x:Name="MonitorInterval" Minimum="10" Maximum="300" Value="30"
                            TickFrequency="10" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="IntervalDisplay" Text="30 秒" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Account Tab -->
            <TabItem Header="账号">
                <StackPanel Padding="12">
                    <TextBlock Text="当前登录状态" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock x:Name="LoginStatus" Text="已登录" FontSize="14" FontWeight="Medium"/>
                    <Button Content="退出登录" Margin="0,16,0,0" Padding="16,8"
                            Click="OnLogout" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Click="OnCancel" Padding="16,6" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="#333"/>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="保存" Click="OnSave" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
